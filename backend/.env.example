# Backend environment variables
# Most values have defaults in config.py or are passed from docker-compose.
# Only override here if you need to diverge from the compose defaults.

# --- App ---
# APP_ENV=preprod              # preprod | prod | dev
# APP_DEBUG=true

# --- Database (set by docker-compose) ---
# DATABASE_URL=postgresql+psycopg://app:devpassword@postgres:5432/hosting

# --- Security (set by docker-compose) ---
# SESSION_SECRET=dev-session-secret-change-me-in-prod

# --- Keycloak (set by docker-compose) ---
# KEYCLOAK_SERVER_URL=http://keycloak:8080
# KEYCLOAK_REALM=hosting-dev
# KEYCLOAK_CLIENT_ID=hosting
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/auth/callback
# KEYCLOAK_VERIFY_TLS=false

# --- Auth claims ---
# AUTH_GROUPS_CLAIM=groups
# AUTH_ATTRIBUTES_NAMESPACE=attributes
# AUTH_USER_GROUPS=hosting-users    # Only enforced in preprod mode
# AUTH_ADMIN_GROUPS=admin

# --- Resources ---
# RESOURCE_MAX_CPU_CORES=6
# RESOURCE_MAX_RAM_GB=9
# RESOURCE_MAX_DISK_GB=30
# VM_MIN_CPU_CORES=1
# VM_MIN_RAM_GB=2
# VM_MIN_DISK_GB=10

# VM_NAME_MAX_LENGTH=10

# --- Network ---
# VM_IPV4_SUBNETS=157.159.195.0/24
# VM_IPV4_GATEWAY_HOSTS=1
# VM_IPV6_SUBNET=2001:660:3203:40a::/64
# VM_IPV6_GATEWAY_HOST=1
# VM_ID_MIN=2001

# --- Proxmox ---
# Base URL defaults to luna.priv.minet.net:8006, TLS verify off.
# Only TOKEN_ID and TOKEN_SECRET need to be provided (set in root .env).
# PROXMOX_BASE_URL=https://luna.priv.minet.net:8006
# PROXMOX_TOKEN_ID=user@pve!my-token
# PROXMOX_TOKEN_SECRET=
# PROXMOX_NODE=pve

# --- PowerDNS (set by docker-compose) ---
# PDNS_API_URL=http://pdns:8081
# PDNS_API_KEY=devkey
# DNS_ZONE=h.lan

# --- SMTP (optional in dev) ---
# SMTP_HOST=192.168.102.18
# SMTP_PORT=25
# SMTP_FROM=hosting@minet.net

# --- Frontend CORS ---
# FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
