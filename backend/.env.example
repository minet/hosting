APP_NAME=hosting-api
APP_ENV=dev
APP_DEBUG=true
APP_PORT=8000

# Security
JWT_ALGORITHM=RS256
JWT_LEEWAY_SECONDS=30

# PostgreSQL
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=hosting
POSTGRES_USER=app
POSTGRES_PASSWORD=app
DATABASE_URL=postgresql+psycopg://app:app@host.docker.internal:5432/hosting
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SECONDS=10
RESOURCE_MAX_CPU_CORES=6
RESOURCE_MAX_RAM_GB=9
RESOURCE_MAX_DISK_GB=30
VM_MIN_CPU_CORES=1
VM_MIN_RAM_GB=2
VM_MIN_DISK_GB=10
VM_IPV4_SUBNET=157.159.195.0/24
VM_IPV4_GATEWAY_HOST=1
VM_IPV6_SUBNET=2001:660:3203:40a::/64
VM_IPV6_GATEWAY_HOST=1
VM_ID_MIN=2001

# Keycloak
KEYCLOAK_SERVER_URL=https://keycloak.minet.net
KEYCLOAK_REALM=MiNET
KEYCLOAK_CLIENT_ID=hosting
KEYCLOAK_CLIENT_SECRET=
# Must match exactly a Valid Redirect URI configured in Keycloak.
KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/auth/callback
KEYCLOAK_VERIFY_TLS=true
KEYCLOAK_TIMEOUT_SECONDS=10

# Claims strategy: groups / attributes
AUTH_GROUPS_CLAIM=groups
AUTH_ATTRIBUTES_NAMESPACE=attributes
AUTH_USER_GROUPS=
AUTH_ADMIN_GROUPS=/cluster-prod
FRONTEND_ALLOWED_ORIGINS=

# Proxmox
PROXMOX_BASE_URL=https://192.168.104.71:8006
PROXMOX_VERIFY_TLS=false
PROXMOX_TIMEOUT_SECONDS=10
PROXMOX_TOKEN_ID=hosting-api
PROXMOX_TASK_TIMEOUT_SECONDS=300
PROXMOX_NODE=pve
PROXMOX_TOKEN_SECRET=
PROXMOX_USER=
PROXMOX_PASSWORD=

# PowerDNS
# URL interne du container PowerDNS (API REST)
PDNS_API_URL=http://pdns:8081
PDNS_API_KEY=changeme
# Zone DNS déléguée à ce serveur PowerDNS
# Dev  : h.lan
# Prod : h.minet.net  (déléguer via NS record chez MiNET)
DNS_ZONE=h.lan
