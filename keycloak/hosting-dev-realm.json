      "name": "Hosting Platform",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
